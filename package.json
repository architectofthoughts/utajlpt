{
  "name": "utajlpt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-vocab.mjs && tsc -b && vite build",
    "build:vocab": "node scripts/build-vocab.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=utajlpt --branch=main",
    "db:migrate:local": "wrangler d1 execute DB --file=./migrations/0001_initial_schema.sql --local --persist-to .wrangler/state",
    "db:migrate:remote": "wrangler d1 execute DB --file=./migrations/0001_initial_schema.sql --remote"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^3.4.17",
    "tar": "^7.5.13",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "svelte-spa-router": "^4.0.1"
  }
}
